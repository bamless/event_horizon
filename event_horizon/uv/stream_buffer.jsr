import event_horizon.data_structures.deque for Deque

class StreamBuffer
    construct()
        this._chunks = Deque()
        this._state = null
        this._initState()
    end

    native _initState()
    native pushBack(data)
    native drainN(n)
    native drainUntilSep(sep)
    native drainAll()
    native __len__()
end
