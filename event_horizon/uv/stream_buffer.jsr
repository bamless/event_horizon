import event_horizon.data_structures.deque for Deque

class StreamBuffer
    construct()
        this._chunks = Deque()
        this._state = null
        this._init()
    end

    native pushBack(data)
    native drainN(n)
    native drainUntilSep(sep)
    native drainAll()
    native __len__()
    native _init()
end
