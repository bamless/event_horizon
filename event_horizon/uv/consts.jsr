import sys

/// Address families accepted by socket and DNS APIs.
var Family = Enum(
    'AF_UNSPEC',
    'AF_INET',
    'AF_INET6'
)

/// Socket types accepted by DNS APIs.
var SockType = Enum(
    'SOCK_STREAM',
    'SOCK_DGRAM'
)

// AI_IDN and AI_CANONIDN are GNU extensions available only on Linux.
// They are included in the Enum at runtime so the names remain visible
// here for documentation, but must not be used on other platforms.
static var _gnuAIFlags = ('AI_IDN', 'AI_CANONIDN')

/// getaddrinfo flags accepted by DNS APIs.
var AIFlags = Enum(
    'AI_PASSIVE',
    'AI_CANONNAME',
    'AI_NUMERICHOST',
    'AI_V4MAPPED',
    'AI_ALL',
    'AI_ADDRCONFIG',
    'AI_NUMERICSERV',
    ...(_gnuAIFlags if sys.platform() == "Linux" else ()),
)

static native _consts_init()
_consts_init()
