#!/usr/bin/env jstar
importPaths.insert(0, './')
importPaths.insert(0, './tests')

import event_horizon.uv.stream_buffer for StreamBuffer

import test for test, run

// ---------------------------------------------------------------------------
// pushBack / size / __len__
// ---------------------------------------------------------------------------

@test
fun pushBackAndSize()
    var b = StreamBuffer()
    assert(#b == 0)
    b.pushBack("hello")
    assert(#b == 5)
    b.pushBack(" world")
    assert(#b == 11)
end

// ---------------------------------------------------------------------------
// drainAll
// ---------------------------------------------------------------------------

@test
fun drainAllEmpty()
    var b = StreamBuffer()
    assert(b.drainAll() == null)
end

@test
fun drainAllSingleChunk()
    var b = StreamBuffer()
    b.pushBack("hello")
    assert(b.drainAll() == "hello")
    assert(#b == 0)
end

@test
fun drainAllMultipleChunks()
    var b = StreamBuffer()
    b.pushBack("foo")
    b.pushBack("bar")
    b.pushBack("baz")
    assert(b.drainAll() == "foobarbaz")
    assert(#b == 0)
end

@test
fun drainAllResetsBuffer()
    var b = StreamBuffer()
    b.pushBack("data")
    b.drainAll()
    assert(b.drainAll() == null)
    b.pushBack("new")
    assert(b.drainAll() == "new")
end

// ---------------------------------------------------------------------------
// drainN
// ---------------------------------------------------------------------------

@test
fun drainNNotEnoughData()
    var b = StreamBuffer()
    b.pushBack("hi")
    assert(b.drainN(10) == null)
    assert(#b == 2)  // nothing was consumed
end

@test
fun drainNExact()
    var b = StreamBuffer()
    b.pushBack("hello")
    assert(b.drainN(5) == "hello")
    assert(#b == 0)
end

@test
fun drainNPartial()
    var b = StreamBuffer()
    b.pushBack("hello world")
    assert(b.drainN(5) == "hello")
    assert(#b == 6)
    assert(b.drainN(6) == " world")
    assert(#b == 0)
end

@test
fun drainNAcrossChunks()
    var b = StreamBuffer()
    b.pushBack("foo")
    b.pushBack("bar")
    assert(b.drainN(4) == "foob")
    assert(#b == 2)
    assert(b.drainN(2) == "ar")
    assert(#b == 0)
end

@test
fun drainNThenDrainAll()
    var b = StreamBuffer()
    b.pushBack("abcdef")
    b.drainN(3)
    assert(b.drainAll() == "def")
end

// ---------------------------------------------------------------------------
// findSepEnd
// ---------------------------------------------------------------------------

@test
fun findSepEndNotFound()
    var b = StreamBuffer()
    b.pushBack("hello")

    assert(b.findSepEnd("\n") == null)
    assert(#b == 5)
end

@test
fun findSepEndEmptySep()
    var b = StreamBuffer()
    b.pushBack("hello")

    var threw = false
    try
        b.findSepEnd("")
    except InvalidArgException e
        threw = true
    end

    assert(threw)
    assert(#b == 5)
end

if __name__ == '__main__'
    run()
end
