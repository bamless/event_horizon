#!/usr/bin/env jstar
importPaths.insert(0, './')
importPaths.insert(0, './tests')

import test for test, run

import event_horizon.uv as uv
import event_horizon.errors for LoopExecutionException

@test
fun callSoonFires()
    var called = false
    uv.loop().callSoon(fun()
        called = true
    end)

    assert(!called, "callSoon callback must not fire synchronously")
    uv.loop().runForever()
    assert(called)
end

@test
fun callSoonInOrder()
    var order = []
    uv.loop().callSoon(fun() order.add(1) end)
    uv.loop().callSoon(fun() order.add(2) end)
    uv.loop().callSoon(fun() order.add(3) end)

    uv.loop().runForever()

    assert(order[0] == 1 and order[1] == 2 and order[2] == 3)
end

@test
fun callSoonCascade()
    // A callback enqueued by a running callback is processed by a later loop
    // turn. runForever() still keeps going while that next turn is armed.
    var order = []
    uv.loop().callSoon(fun()
        order.add(1)
        uv.loop().callSoon(fun()
            order.add(2)
            uv.loop().callSoon(fun()
                order.add(3)
            end)
        end)
    end)

    uv.loop().runForever()

    assert(#order == 3 and order[0] == 1 and order[1] == 2 and order[2] == 3)
end

@test
fun callSoonCascadeDoesNotStarveTimers()
    var timerFired = false
    var count = 0

    fun spin()
        count += 1
        if !timerFired
            uv.loop().callSoon(spin)
        end
    end

    uv.loop().callLater(20, fun()
        timerFired = true
    end)
    uv.loop().callSoon(spin)

    uv.loop().runForever()

    assert(timerFired, "timer was starved by recursively scheduled callSoon callbacks")
    assert(count > 0, "callSoon callback did not run")
end

@test
fun callSoonExceptionSurfaces()
    // An exception thrown inside a callSoon callback must surface as a
    // LoopExecutionException after run() — not silently swallowed.
    uv.loop().callSoon(fun()
        raise Exception("boom")
    end)

    var caught = false
    try
        uv.loop().runForever()
    except LoopExecutionException e
        caught = true
        assert(e.cause() is Exception and e.cause().err() == "boom")
    end

    assert(caught, "LoopExecutionException not raised")
end

@test
fun callSoonExceptionContinuesDrain()
    // An exception in one callback must not prevent subsequent callbacks in the
    // same batch from running.
    var reached = false
    uv.loop().callSoon(fun()
        raise Exception("first")
    end)
    uv.loop().callSoon(fun()
        reached = true
    end)

    try
        uv.loop().runForever()
    except LoopExecutionException _
    end

    assert(reached, "second callback was skipped after exception in first")
end

@test
fun callSoonMultipleExceptions()
    // All exceptions from a single drain must be bundled into one
    // LoopExecutionException with exceptions() returning every cause.
    uv.loop().callSoon(fun() raise Exception("one") end)
    uv.loop().callSoon(fun() raise Exception("two") end)
    uv.loop().callSoon(fun() raise Exception("three") end)

    var caught = false
    try
        uv.loop().runForever()
    except LoopExecutionException e
        caught = true
        assert(#e.exceptions() == 3)
        assert(e.exceptions()[0].err() == "one")
        assert(e.exceptions()[1].err() == "two")
        assert(e.exceptions()[2].err() == "three")
    end

    assert(caught, "LoopExecutionException not raised")
end

if __name__ == '__main__'
    run()
end
