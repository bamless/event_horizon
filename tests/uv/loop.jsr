#!/usr/bin/env jstar
importPaths.insert(0, './')
importPaths.insert(0, './tests')

import test for test, run

import event_horizon.uv as uv
import event_horizon.uv.event_loop as event_loop
import event_horizon.uv.tcp for TCP

@test
fun create()
    var loop = event_loop.EventLoop() 
    assert(loop._id != -1)

    var fromId = event_loop.getEventLoop(loop._id) 
    assert(fromId == loop)
end

@test
fun runForever()
    var loop = event_loop.EventLoop()
    loop.runForever()
end

@test
fun globalLoopRun()
    uv.loop().runForever()
end

@test
fun stop()
    var loop = event_loop.EventLoop()
    var tcp = TCP(loop)
    var closed = false

    tcp.close(fun()
        closed = true
        loop.stop()
    end)

    loop.runForever()
    assert(closed, "Loop should have closed stream")
end

@test
fun notAlive()
    assert(!uv.loop()._alive(), "Loop should not be alive")
end

@test
fun close()
    var loop = event_loop.EventLoop()

    assert(!loop.isClosed(), "Loop should start open")
    loop.close()
    assert(loop.isClosed(), "Loop should report closed after close()")

    // once closed, repeated close calls are harmless, but running or
    // scheduling native work on the loop is not.
    loop.close()

    var didThrow = false
    try
        loop.runForever()
    except Exception e
        didThrow = true
    end

    assert(didThrow, "Closed loop should not run")
end

@test
fun alive()
    var tcp = TCP()
    
    tcp.connect('0.0.0.0', 8080, fun(status)
        tcp.close(fun()
            assert(!uv.loop()._alive(), "Loop should not be alive")
        end) 
        assert(uv.loop()._alive(), "Loop should be alive")
    end)

    uv.loop().runForever()

    assert(!uv.loop()._alive(), "Loop should not be alive")
end

@test
fun walk()
    var tcp1 = TCP()
    var tcp2 = TCP()

    var count = 0
    uv.loop()._walk(fun(handle)
        count += 1 
        handle.close()
    end)

    assert(count == 2, "Wrong number of handles in `EventLoop._walk()`: {0}" % count)

    uv.loop().runForever()

    count = 0
    uv.loop()._walk(fun(handle)
        count += 1 
    end)
 
    assert(count == 0, "Second walk should not find any handle")
end

if __name__ == '__main__'
    run()
end
