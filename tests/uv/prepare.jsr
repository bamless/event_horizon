#!/usr/bin/env jstar
importPaths.insert(0, './')
importPaths.insert(0, './tests')

import test for test, run

import event_horizon.uv as uv
import event_horizon.uv.prepare for Prepare

@test
fun prepare()
    var prepare = Prepare()
    var called = false

    prepare.start(fun()
        called = true
        prepare.close()
    end)

    uv.loop().runForever()

    assert(called)
end

@test
fun stop()
    var prepare = Prepare()
    var called = false

    prepare.start(fun()
        called = true
    end)
    prepare.stop()
    prepare.close()

    uv.loop().runForever()

    assert(!called)
end

if __name__ == '__main__'
    run()
end
