#!/usr/bin/env jstar
importPaths.insert(0, './')
importPaths.insert(0, './tests')

import test for test, run, skip
import server_utils for withTCPServer

import event_horizon.errors for EventHorizonException, StatusException, LoopExecutionException
import event_horizon.uv.errors for strerror
import event_horizon.uv as uv
import event_horizon.uv.tcp for TCP

@test
fun shutdown()
    withTCPServer(8080, fun(server, client)
        client.readStart(fun(_, status)
            if status < 0
                raise StatusException(status)
            end
            client.close()
            server.close()
        end)
    end)

    var tcp = TCP() 
    var shut = false
    
    tcp.connect("0.0.0.0", 8080, fun(status)
        tcp.shutdown(fun(status)
            assert(#tcp._callbacks == 0)
            assert(status >= 0)
            shut = true
            tcp.close()
        end)

        assert(#tcp._callbacks == 1)
    end)

    assert(!shut, '`shutdown` called before next loop tick')
    uv.loop().run()
    assert(shut, '`shutdown` not called')
end

@test
fun shutdownFail()
    var tcp = TCP() 
    
    tcp.connect("0.0.0.0", 80, fun(status)
        tcp.shutdown(fun(status)
            assert(strerror(status) == 'socket is not connected')
            tcp.close()
        end)
    end)

    uv.loop().run()
end

@test
fun shutdownThrows()
    var tcp = TCP() 
    
    tcp.connect("0.0.0.0", 80, fun(status)
        tcp.shutdown(fun(status)
            tcp.close()
            raise NameException()
        end)
    end)
    
    var didThrow = false
    try
        uv.loop().run()
    except LoopExecutionException e
        didThrow = true
        assert(e.cause() is NameException, "Chained exception is of wrong type: {0}" % type(e.cause()))
    end

    assert(didThrow, "`uv.loop().run()` Did not propagate the exception")
end

@test
fun shutdownMultipleThrows()
    var tcp1 = TCP()
    tcp1.connect("0.0.0.0", 80, fun(status)
        tcp1.shutdown(fun(status)
            tcp1.close()
            raise NameException()
        end)
    end)

    var tcp2 = TCP()
    tcp2.connect("0.0.0.0", 80, fun(status)
        tcp2.shutdown(fun(status)
            tcp2.close()
            raise TypeException()
        end)
    end)
    
    var didThrow = false
    try
        uv.loop().run()
    except LoopExecutionException e
        didThrow = true
        var exceptions = e.exceptions()
        assert(#exceptions == 2, "Too many exceptions: {0}" % #exceptions)
        assert(exceptions.find(|e| => e is NameException), "Expected to find a `NameException`")
        assert(exceptions.find(|e| => e is TypeException), "Expected to find a `TypeException`")
    end

    assert(didThrow, "`uv.loop().run()` Did not propagate the exception")
end

@test
fun write()
    var s = TCP()
    var data = "Hello, World!"
    var received = ""

    withTCPServer(8080, fun(server, client)
        client.readStart(fun(read, status)
            if status < 0
                raise StatusException(status)
            end
            if !read
                client.close()
                server.close()
                return
            end
            received += read
        end)
    end)

    s.connect("127.0.0.1", 8080, fun(status)
        if status < 0
            s.close()
            raise StatusException(status)
        end

        s.write(data, fun(status)
            s.close()
            if status < 0
                raise StatusException(status)
            end
        end)
    end)

    uv.loop().run()

    assert(#s._callbacks == 0)
    assert(received == data, "'{0}' != '{1}'" % (received, data))
end

@test
fun twoWrite()
    var s = TCP()
    var data = "Hello, World!"
    var received = ""

    withTCPServer(8080, fun(server, client)
        client.readStart(fun(read, status)
            if status < 0
                raise StatusException(status)
            end
            if !read
                client.close()
                server.close()
                return
            end
            received += read
        end)
    end)

    s.connect("127.0.0.1", 8080, fun(status)
        if status < 0
            s.close()
            raise StatusException(status)
        end

        var writesDone = 0
        s.write(data, fun(status)
            if status < 0
                raise StatusException(status)
            end
            writesDone += 1
            if writesDone == 2
                s.close()
            end
        end)

        s.write(data, fun(status)
            if status < 0
                raise StatusException(status)
            end
            writesDone += 1
            if writesDone == 2
                s.close()
            end
        end)
    end)

    uv.loop().run()

    assert(#s._callbacks == 0)
    assert(received == data * 2, "'{0}' != '{1}'" % (received, data * 2))
end

@test
fun writeFail()
    var s = TCP()
    var data = "Hello, World!"
    var received = ""

    withTCPServer(8080, fun(server, client)
        client.readStart(fun(read, status)
            if status < 0
                raise StatusException(status)
            end
            if !read
                client.close()
                server.close()
                return
            end
            received += read
        end)
    end)

    s.connect("127.0.0.1", 8080, fun(status)
        s.close()
        if status < 0
            raise StatusException(status)
        end
        s.write(data)
    end)

    var didThrow = false

    try
        uv.loop().run()
    except LoopExecutionException e
        didThrow = true
        assert(e.cause() is EventHorizonException and e.cause().err() == "Handle is already closed", "Wrong exception type: {0}" % type(e.cause()).getName())
    end


    assert(didThrow)
    assert(received == '', "Non empty server result: {0}" % received)
end

@test
fun writeThrows()
    var s = TCP()
    var data = "Hello, World!"
    var received = ""

    withTCPServer(8080, fun(server, client)
        client.readStart(fun(read, status)
            if status < 0
                raise StatusException(status)
            end
            if !read
                client.close()
                server.close()
                return
            end
            received += read
            if received == data
                client.close()
                server.close()
            end
        end)
    end)

    s.connect("127.0.0.1", 8080, fun(status)
        if status < 0
            s.close()
            raise StatusException(status)
        end

        s.write(data, fun(status)
            s.close()
            raise Exception()
        end)
    end)

    var didThrow = false

    try
        uv.loop().run()
    except Exception e
        didThrow = true
    end

    assert(didThrow)
    assert(received == data, "'{0}' != '{1}'" % (received, data))
end

@test
fun tryWrite()
    var s = TCP()
    var data = "Hello, World!"
    var received = ""

    withTCPServer(8080, fun(server, client)
        client.readStart(fun(read, status)
            if status < 0
                raise StatusException(status)
            end
            if !read
                client.close()
                server.close()
                return
            end
            received += read
        end)
    end)

    s.connect("127.0.0.1", 8080, fun(status)
        if status < 0
            s.close()
            raise StatusException(status)
        end

        var sent = s.tryWrite(data)
        assert(sent <= #data, "Sent more bytes than data")

        s.close()
    end)

    uv.loop().run()
    assert(data.startsWith(received), "{0} does not start with {1}" % (data, received))
end

@test
fun tryWriteFail()
    var s = TCP()
    var data = "Hello, World!"
    
    var didThrow = false
    try
        var sent = s.tryWrite(data)
    except StatusException e
        didThrow = true
        assert(e.err() == 'bad file descriptor')
    ensure
        s.close()
    end

    assert(didThrow, "tryWrite did not throw")

    uv.loop().run()
end

@test
fun read()
    var s = TCP()
    var data = "Hello, World!"

    withTCPServer(8080, fun(server, client)
        client.write(data, fun(status)
            if status < 0
                raise StatusException(status)
            end
            client.close()
            server.close()
        end)
    end)

    s.connect("127.0.0.1", 8080, fun(status)
        if status < 0
            s.close()
            raise StatusException(status)
        end

        s.readStart(fun(read, status)
            assert(#s._callbacks == 1)

            if status < 0
                raise StatusException(status)
            end

            s.close()
            
            assert(read == data, '{0} != {1}' % (read, data)) 
        end)
    end)

    uv.loop().run()
end

@test
fun read()
    var s = TCP()
    var data = "Hello, World!"

    withTCPServer(8080, fun(server, client)
        client.write(data, fun(status)
            if status < 0
                raise StatusException(status)
            end
            client.close()
            server.close()
        end)
    end)

    s.connect("127.0.0.1", 8080, fun(status)
        if status < 0
            s.close()
            raise StatusException(status)
        end

        s.readStart(fun(read, status)
            var didThrow = false

            try
                s.readStart(fun(read, status) end)
            except StatusException e
                didThrow = true
                assert(e.err() == 'connection already in progress')
            end


            if status < 0
                raise StatusException(status)
            end

            s.close()

            assert(didThrow, "second readStart did not throw")
        end)
    end)

    uv.loop().run()
end

