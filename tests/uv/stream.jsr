@test
fun readStop()
    var s = TCP()
    var data = "Hello, World!"
    var accepted = null
    var server = TCP()
    server.bind("0.0.0.0", 8080)
    server.listen(fun(client, status)
        if status < 0
            server.close()
            raise StatusException(status)
        end
        accepted = client
        server.close()
        accepted.write(data, fun(status)
            if status < 0
                raise StatusException(status)
            end
        end)
    end)

    var numCalled = 0
    s.connect("127.0.0.1", 8080, fun(status)
        if status < 0
            s.close()
            raise StatusException(status)
        end

        s.readStart(fun(read, status)
            numCalled += 1

            if status < 0
                raise StatusException(status)
            end

            s.readStop()        
            assert(read == data, '{0} != {1}' % (read, data)) 
        end)
    end)

    uv.loop().run()

    assert(!s.isClosing())

    accepted.write("Hello, World!", fun(status)
        if status < 0
            raise StatusException(status)
        end
    end)
    uv.loop().run()

    s.close()
    accepted.close()
    uv.loop().run()

    assert(numCalled == 1, "read called more than one time")
end

@test
fun readThrows()
    var s = TCP()

    withTCPServer(8080, fun(server, client)
        client.write("foo", fun(status)
            if status < 0
                raise StatusException(status)
            end
            client.close()
            server.close()
        end)
    end)

    s.connect("127.0.0.1", 8080, fun(status)
        if status < 0
            s.close()
            raise StatusException(status)
        end

        s.readStart(fun(read, status)
            s.close()
            raise NameException()
        end)
    end)

    var didThrow = false
    try
        uv.loop().run()
    except LoopExecutionException e
        didThrow = true
        assert(e.cause() is NameException)
    end

    assert(didThrow, '`uv.loop().run() did not throw')
end

@test
fun listen()
    var s = TCP()
    var c = TCP()

    s.bind('0.0.0.0', 8080)

    var listenCalled = false
    s.listen(fun(client, status)
        listenCalled = true

        if status < 0
            s.close()
            raise StatusException(status)
        end

        client.close()
        s.close()
    end)

    c.connect('0.0.0.0', 8080, fun(status)
        c.close()
    end)

    uv.loop().run()
end

@test
fun isReadableWritable()
    withTCPServer(8080, fun(server, client)
        client.readStart(fun(_, status)
            if status < 0
                raise StatusException(status)
            end
            client.close()
            server.close()
        end)
    end)
    var s = TCP()

    assert(!s.isReadable() and !s.isWritable(), "Socket not conneted, should not be readable or writable")

    s.connect('0.0.0.0', 8080, fun(status)
        if status < 0
            s.close()
            raise StatusException(status)
        end

        assert(s.isReadable() and s.isWritable(), "Connected socket should be readable and writable")

        s.shutdown(fun(status)
            if status < 0
                s.close()
                raise StatusException(status)
            end

            assert(s.isReadable() and !s.isWritable(), "Shut socket should only be readable")
            s.close()
        end)
    end)

    uv.loop().run()
end

@test
fun getWriteQueueSize()
    var s = TCP()
    var sz = s.getWriteQueueSize()
    assert(sz is Number and sz >= 0)
    s.close()
    uv.loop().run()
end

if __name__ == '__main__'
    run()
end
