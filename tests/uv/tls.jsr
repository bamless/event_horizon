#!/usr/bin/env jstar
importPaths.insert(0, './')
importPaths.insert(0, './tests')

import test for test, run
import server_utils for withTLSServer

import event_horizon.errors for EventHorizonException, LoopExecutionException, StatusException
import event_horizon.uv.errors for Errno
import event_horizon.uv as uv
import event_horizon.uv.tls for TLS

static var CERT = "tests/certs/cert.pem"
static var KEY  = "tests/certs/key.pem"
static var PORT = 8088

static fun repeatedBlock(block, count)
    var chunks = []
    while count > 0
        chunks.add(block)
        count = count - 1
    end
    return chunks.join()
end

static fun closeIgnoringAlreadyClosing(stream)
    try
        stream.close()
    except StatusException e
        if e.status() != Errno.EALREADY
            raise e
        end
    end
end

@test
fun handshake()
    var handshakeDone = false

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.close()
    end)

    var c = TLS()   // client with no CA == VERIFY_NONE
    c.connect("127.0.0.1", PORT, null, fun(status)
        assert(status == 0, "Handshake failed with status: {0}" % status)
        handshakeDone = true
        c.close()
    end)

    uv.loop().run()
    assert(handshakeDone, "Handshake callback never fired")
end

@test
fun serverRequiresCertificatePair()
    var missingBoth = false
    try
        TLS(null, null, true)
    except InvalidArgException e
        missingBoth = true
    end
    assert(missingBoth, "server TLS without cert/key did not throw")

    var missingKey = false
    try
        TLS({"cert": CERT}, null, true)
    except InvalidArgException e
        missingKey = true
    end
    assert(missingKey, "server TLS without key did not throw")
end

@test
fun clientCertificateRequiresKeyPair()
    var missingKey = false
    try
        TLS({"cert": CERT})
    except InvalidArgException e
        missingKey = true
    end
    assert(missingKey, "client TLS with only cert did not throw")

    var missingCert = false
    try
        TLS({"key": KEY})
    except InvalidArgException e
        missingCert = true
    end
    assert(missingCert, "client TLS with only key did not throw")
end

@test
fun handshakeWithCA()
    var verified = false

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.close()
    end)

    var c = TLS({"ca": CERT})
    c.connect("127.0.0.1", PORT, "localhost", fun(status)
        assert(status == 0, "Verified handshake failed: {0}" % status)
        verified = true
        c.close()
    end)

    uv.loop().run()
    assert(verified)
end

@test
fun handshakeBadCA()
    var failStatus = null

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.close()
    end)

    // Generate a different CA by reusing the same cert but with a wrong CN;
    // in this test we just use the server cert itself as a "bad" CA for a
    // different expected hostname so verification fails.
    var c = TLS({"ca": CERT})
    c.connect("127.0.0.1", PORT, "wrong.hostname", fun(status)
        // mbedTLS CN mismatch -> handshake fails -> status == UV_EPROTO
        failStatus = status
        c.close()
    end)

    uv.loop().run()
    assert(failStatus != null and failStatus == Errno.EPROTO, "Expected handshake failure")
end

@test
fun writeRead()
    // Full echo round-trip: server reads a message and writes it back
    var received = null

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.readStart(fun(data, status)
            if status < 0
                closeIgnoringAlreadyClosing(client)
                return
            end
            // Echo back
            client.write(data, fun(wStatus)
                client.close()
            end)
        end)
    end)

    var c = TLS()
    c.connect("127.0.0.1", PORT, null, fun(status)
        assert(status == 0)
        c.write("hello TLS", fun(wStatus)
            assert(wStatus == 0)
            c.readStart(fun(data, rStatus)
                received = data
                c.readStop()
                c.close()
            end)
        end)
    end)

    uv.loop().run()
    assert(received == "hello TLS", "Expected 'hello TLS', got: {0}" % received)
end

@test
fun largeWriteQueuesWithoutSynchronousEAGAIN()
    var block = repeatedBlock("x", 4096)
    var large = repeatedBlock(block, 256)
    var didThrow = false
    var writeCallbackFired = false
    var serverRead = 0

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.readStart(fun(data, status)
            if status < 0
                closeIgnoringAlreadyClosing(client)
                return
            end
            if !data
                closeIgnoringAlreadyClosing(client)
                return
            end
            serverRead += #data
            if serverRead >= #large
                client.close()
            end
        end)
    end)

    var c = TLS()
    c.connect("127.0.0.1", PORT, null, fun(status)
        assert(status == 0)
        try
            c.write(large, fun(writeStatus)
                assert(writeStatus == 0)
                writeCallbackFired = true
                c.close()
            end)
        except StatusException e
            didThrow = true
        end
    end)

    uv.loop().run()
    assert(!didThrow, "large TLS write unexpectedly threw")
    assert(writeCallbackFired, "large TLS write callback did not fire")
    assert(serverRead == #large, "server did not read the full large write")
end

@test
fun emptyWriteCompletesAndDoesNotBlockNextWrite()
    var emptyWriteDone = false
    var nextWriteDone = false
    var received = null

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.readStart(fun(data, status)
            if status < 0 or !data
                closeIgnoringAlreadyClosing(client)
                return
            end
            received = data
            client.close()
        end)
    end)

    var c = TLS()
    c.connect("127.0.0.1", PORT, null, fun(status)
        assert(status == 0)
        c.write("", fun(writeStatus)
            assert(writeStatus == 0)
            emptyWriteDone = true
        end)
        c.write("after empty", fun(writeStatus)
            assert(writeStatus == 0)
            nextWriteDone = true
            c.close()
        end)
    end)

    uv.loop().run()
    assert(emptyWriteDone, "empty TLS write callback did not fire")
    assert(nextWriteDone, "write after empty TLS write did not complete")
    assert(received == "after empty", "write after empty TLS write was not delivered")
end

@test
fun pendingWriteQueueSizeTracksUnencryptedPlaintext()
    var block = repeatedBlock("p", 4096)
    var large = repeatedBlock(block, 256)
    var queuedAfterWrite = null
    var queuedAfterCallback = null
    var serverRead = 0

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.readStart(fun(data, status)
            if status < 0 or !data
                closeIgnoringAlreadyClosing(client)
                return
            end
            serverRead += #data
            if serverRead >= #large
                client.close()
            end
        end)
    end)

    var c = TLS()
    c.connect("127.0.0.1", PORT, null, fun(status)
        assert(status == 0)
        c.write(large, fun(writeStatus)
            assert(writeStatus == 0)
            queuedAfterCallback = c.pendingWriteQueueSize()
            c.close()
        end)
        queuedAfterWrite = c.pendingWriteQueueSize()
    end)

    uv.loop().run()
    assert(queuedAfterWrite > 0, "large TLS write did not report queued plaintext")
    assert(queuedAfterCallback == 0, "TLS pending write queue did not drain")
    assert(serverRead == #large, "server did not read the full large write")
end

@test
fun closeWhileWriteInFlightDrainsAndCloses()
    // Closing right after a large write (while its ciphertext is still draining
    // through libuv) must defer the close, finish the drain, then run the close
    // callback. Regression guard for the closePendingDrain path.
    var block = repeatedBlock("z", 4096)
    var large = repeatedBlock(block, 256)
    var closeCallbackFired = false
    var writeFailed = false
    var serverRead = 0

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.readStart(fun(data, status)
            if status < 0 or !data
                closeIgnoringAlreadyClosing(client)
                return
            end
            serverRead += #data
            if serverRead >= #large
                client.close()
            end
        end)
    end)

    var c = TLS()
    c.connect("127.0.0.1", PORT, null, fun(status)
        assert(status == 0)
        c.write(large, fun(status)
            if status < 0
                writeFailed = true
            end
        end)
        // Close immediately: the write is still in flight.
        c.close(fun()
            closeCallbackFired = true
        end)
    end)

    uv.loop().run()
    assert(closeCallbackFired, "close callback did not fire after in-flight write drained")
    assert(writeFailed, "Writes should fail when closed before flushing")
end

@test
fun closeWhileClosePendingFailsWithEALREADY()
    // The first close is deferred because TLS still has ciphertext draining.
    // A second close must fail before it can replace the first close callback.
    var block = repeatedBlock("q", 4096)
    var large = repeatedBlock(block, 256)
    var firstCloseCallbackFired = false
    var secondCloseCallbackFired = false
    var didThrow = false
    var serverRead = 0

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.readStart(fun(data, status)
            if status < 0 or !data
                closeIgnoringAlreadyClosing(client)
                return
            end
            serverRead += #data
            if serverRead >= #large
                client.close()
            end
        end)
    end)

    var c = TLS()
    c.connect("127.0.0.1", PORT, null, fun(status)
        assert(status == 0)
        c.write(large, fun(_) end)
        c.close(fun()
            firstCloseCallbackFired = true
        end)

        try
            c.close(fun()
                secondCloseCallbackFired = true
            end)
        except StatusException e
            didThrow = true
            assert(e.status() == Errno.EALREADY, "expected UV_EALREADY, got {0}" % e.status())
        end
    end)

    uv.loop().run()
    assert(didThrow, "second close while TLS close was pending did not throw")
    assert(firstCloseCallbackFired, "first close callback did not fire")
    assert(!secondCloseCallbackFired, "second close callback should not be registered")
end

@test
fun closeConnectedFiresCallback()
    var closeCallbackFired = false

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.close()
    end)

    var c = TLS()
    c.connect("127.0.0.1", PORT, null, fun(status)
        assert(status == 0)
        c.close(fun()
            closeCallbackFired = true
        end)
    end)

    uv.loop().run()
    assert(closeCallbackFired, "close callback did not fire")
    assert(#c._callbacks == 0, "close callback leaked")
end

@test
fun closeCancelsActiveRead()
    var readStatus = null
    var readData = "unset"
    var closeCallbackFired = false

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.readStart(fun(data, status)
            if status < 0 or !data
                closeIgnoringAlreadyClosing(client)
            end
        end)
    end)

    var c = TLS()
    c.connect("127.0.0.1", PORT, null, fun(status)
        assert(status == 0)
        c.readStart(fun(data, status)
            readData = data
            readStatus = status
        end)
        c.close(fun()
            closeCallbackFired = true
        end)
    end)

    uv.loop().run()
    assert(readData == null, "close should cancel read with null data")
    assert(readStatus == Errno.ECANCELED, "expected UV_ECANCELED, got {0}" % readStatus)
    assert(closeCallbackFired, "close callback did not fire")
    assert(#c._callbacks == 0, "read callback leaked after close cancellation")
end

@test
fun closeAfterShutdownCancelsActiveRead()
    var readStatus = null
    var shutdownStatus = null
    var closeCallbackFired = false

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.readStart(fun(data, status)
            if status < 0 or !data
                closeIgnoringAlreadyClosing(client)
            end
        end)
    end)

    var c = TLS()
    c.connect("127.0.0.1", PORT, null, fun(status)
        assert(status == 0)
        c.readStart(fun(_, status)
            readStatus = status
        end)
        c.shutdown(fun(status)
            shutdownStatus = status
        end)
        c.close(fun()
            closeCallbackFired = true
        end)
    end)

    uv.loop().run()
    assert(readStatus == Errno.ECANCELED, "expected UV_ECANCELED, got {0}" % readStatus)
    assert(shutdownStatus == Errno.ECANCELED, "expected shutdown UV_ECANCELED, got {0}" % shutdownStatus)
    assert(closeCallbackFired, "close callback did not fire")
    assert(#c._callbacks == 0, "read callback leaked after close cancellation")
end

@test
fun shutdownWithPendingWriteThrows()
    var block = repeatedBlock("y", 4096)
    var large = repeatedBlock(block, 256)
    var didThrow = false
    var writeCallbackFired = false

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.readStart(fun(data, status)
            if status < 0 or !data
                closeIgnoringAlreadyClosing(client)
            end
        end)
    end)

    var c = TLS()
    c.connect("127.0.0.1", PORT, null, fun(status)
        assert(status == 0)
        c.write(large, fun(writeStatus)
            writeCallbackFired = true
            c.close()
        end)
        try
            c.shutdown()
        except EventHorizonException e
            didThrow = true
            assert(e.err() == "TLS shutdown requires all pending writes to complete")
        end
    end)

    uv.loop().run()
    assert(didThrow, "shutdown with pending TLS writes did not throw")
    assert(writeCallbackFired, "pending TLS write did not complete after rejected shutdown")
end

@test
fun writeAfterShutdownFailsSynchronously()
    var server = TLS({"cert": CERT, "key": KEY})
    server.bind("0.0.0.0", PORT)
    server.listen(fun(client, status)
        assert(status == 0)
        client.close()
        server.close()
    end)

    var didThrow = false
    var writeCallbackFired = false

    var c = TLS()
    c.connect("127.0.0.1", PORT, null, fun(status)
        assert(status == 0)
        c.shutdown(fun(shutdownStatus)
            assert(shutdownStatus == 0)
            try
                c.write("after shutdown", fun(writeStatus)
                    writeCallbackFired = true
                end)
            except StatusException e
                didThrow = true
                assert(e.status() == Errno.EPIPE, "expected UV_EPIPE, got {0}" % e.status())
            ensure
                c.close()
            end
        end)
    end)

    uv.loop().run()
    assert(didThrow, "write after shutdown did not throw")
    assert(!writeCallbackFired, "write callback fired after synchronous uv_write failure")
    assert(#c._callbacks == 0, "write callback leaked after synchronous uv_write failure")
end

@test
fun sockName()
    var server = TLS({"cert": CERT, "key": KEY})
    server.bind("0.0.0.0", PORT)

    var addr, port = server.sockName()
    assert(addr == "0.0.0.0")
    assert(port == PORT)

    server.close()
    uv.loop().run()
end

@test
fun peerName()
    var peerAddr = null

    withTLSServer(PORT, CERT, KEY, fun(client)
        client.close()
    end)

    var c = TLS()
    c.connect("127.0.0.1", PORT, null, fun(status)
        assert(status == 0)
        peerAddr = c.peerName()[0]
        c.close()
    end)

    uv.loop().run()
    assert(peerAddr == "127.0.0.1", "Unexpected peer address: {0}" % peerAddr)
end

@test
fun connectFail()
    var failStatus = null

    var c = TLS()
    c.connect("127.0.0.1", PORT, null, fun(status)
        failStatus = status
        c.close()
    end)

    uv.loop().run()
    assert(failStatus != null and failStatus < 0)
end

if __name__ == '__main__'
    run()
end
