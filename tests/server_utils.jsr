import event_horizon.errors for StatusException
import event_horizon.uv.tcp for TCP
import event_horizon.uv.tls for TLS

fun withTCPServer(port, onClient)
    var server = TCP()
    server.bind("0.0.0.0", port)
    server.listen(fun(client, status)
        if status < 0
            server.close()
            raise StatusException(status)
        end
        onClient(server, client)
    end)
    return server
end

fun withTLSServer(port, cert, key, onClient)
    var server = TLS({"cert": cert, "key": key})
    server.bind("0.0.0.0", port)
    server.listen(fun(client, status)
        if status < 0
            server.close()
            return
        end
        onClient(client)
        server.close()
    end)
    return server
end
