#!/usr/bin/env jstar
importPaths.insert(0, './')
importPaths.insert(0, './tests')

import test for test, run, skip

import event_horizon as evh
import event_horizon.async for async
import event_horizon.errors for CancelledError, EventHorizonException, StatusException
import event_horizon.tcp for TCPStream, TCPListener
import event_horizon.uv.errors for Errno

@test
fun listenConnect()
    var clientConnect, serverConnect = false, false

    @async
    fun server()
        var server = TCPListener()
        server.bind("0.0.0.0", 8080)
        
        server.listen()
        var client = yield server.accept()
        serverConnect = true
        yield client.close()
        yield server.close()
    end

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("127.0.0.1", 8080)
        clientConnect = true
        yield client.close()
    end

    evh.run(evh.all(server(), client()))

    assert(clientConnect and serverConnect)
end

@test
fun listenClose()
    var closed = false

    @async
    fun server()
        var server = TCPListener()
        server.bind("0.0.0.0", 8080)
        
        server.listen()
        var client = yield server.accept()
        yield client.close()
        yield server.close()

        closed = true
    end

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("127.0.0.1", 8080)
        yield client.close()
    end

    assert(!closed)

    evh.run(evh.all(server(), client()))

    assert(closed)
end

@test
fun connectResolveURL()
    var connected = false

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("example.com", 443)
        connected = true
        yield client.close()
    end

    assert(!connected)
    evh.run(client())
    assert(connected)
end

@test
fun connectResolveURLFail()
    var didThrow = false

    @async
    fun client()
        var client = TCPStream()
        try
            yield client.connect("url.invalid", 443)
        except StatusException e
            didThrow = true
            assert(e.err() == "unknown node or service")
        end
        yield client.close()
    end
    
    assert(!didThrow)
    evh.run(client())
    assert(didThrow)
end

@test
fun writeRead()
    @async
    fun server()
        var server = TCPListener()
        server.bind("0.0.0.0", 8080)
        
        server.listen()
        var client = yield server.accept()
        try
            var data = yield client.read()
            yield client.write(data)
        ensure
            yield client.close()
            yield server.close()
        end
    end

    var data

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("127.0.0.1", 8080)
        yield client.write("Hello, World!")
        data = yield client.read()
        yield client.close()
    end

    evh.run(evh.all(server(), client()))

    assert(data == "Hello, World!")
end

