@test
fun writeReadCount()
    @async
    fun server()
        var server = TCPListener()
        server.bind("0.0.0.0", 8080)
        
        server.listen()
        var client = yield server.accept()
        yield client.write("0123456789")
        yield client.close()
        yield server.close()
    end

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("127.0.0.1", 8080)

        var data1 = yield client.read(5)
        assert(data1 == "01234")

        var data2 = yield client.read(1)
        assert(data2 == "5")

        var data3 = yield client.read(4)
        assert(data3 == "6789")

        var data4 = yield client.read(500)
        assert(!data4)

        assert(#client._buffer == 0)

        yield client.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun writeReadCountDelayed()
    @async
    fun server()
        var server = TCPListener()
        server.bind("0.0.0.0", 8080)
        
        server.listen()
        var client = yield server.accept()
        yield client.write("01234")
        yield evh.sleep(1000)
        yield client.write("56789")

        yield client.close()
        yield server.close()
    end

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("127.0.0.1", 8080)

        var data1 = yield client.read(8)
        assert(data1 == "01234567")

        var data2 = yield client.read()
        assert(data2 == "89")

        var data3 = yield client.read()
        assert(!data3)

        assert(#client._buffer == 0)

        yield client.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun writeReadUntil()
    @async
    fun server()
        var server = TCPListener()
        server.bind("0.0.0.0", 8080)
        
        server.listen()
        var client = yield server.accept()
        yield client.write(
            "GET /test HTTP/1.1\r\nHost: test.com\r\n\r\nGET /test2 HTTP/1.1\r\nHost: test.com\r\n\r\n"
        )
        yield client.close()
        yield server.close()
    end

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("127.0.0.1", 8080)

        var data1 = yield client.readUntil("\r\n\r\n")
        assert(data1 == "GET /test HTTP/1.1\r\nHost: test.com\r\n\r\n")

        var data2 = yield client.readUntil("\r\n\r\n")
        assert(data2 == "GET /test2 HTTP/1.1\r\nHost: test.com\r\n\r\n")

        var data3 = yield client.read(500)
        assert(!data3)

        var data4 = yield client.readUntil("\r\n\r\n")
        assert(!data4)

        assert(#client._buffer == 0)

        yield client.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun concurrentReadFailsBeforeDrainingBufferedData()
    @async
    fun server()
        var server = TCPListener()
        server.bind("0.0.0.0", 8080)

        server.listen()
        var client = yield server.accept()
        yield client.write("hello")
        yield evh.sleep(100)
        yield client.write(" world\n")

        yield client.close()
        yield server.close()
    end

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("127.0.0.1", 8080)

        var pendingLine = evh.createTask(client.readLine())

        var attempts = 0
        while #client._buffer == 0 and attempts < 20
            attempts += 1
            yield evh.sleep(10)
        end
        assert(#client._buffer > 0, "partial line was not buffered before concurrent read")

        try
            yield client.read()
            assert(false, "concurrent read should have failed")
        except StatusException e
            assert(e.status() == Errno.EALREADY, "expected UV_EALREADY, got {0}" % e.status())
        end

        var line = yield pendingLine
        assert(line == "hello world\n")

        yield client.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun cancelledReadReleasesPendingReadState()
    @async
    fun server()
        var server = TCPListener()
        server.bind("0.0.0.0", 8080)

        server.listen()
        var client = yield server.accept()
        yield client.write("hello")
        yield evh.sleep(100)
        yield client.write(" world\n")

        yield client.close()
        yield server.close()
    end

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("127.0.0.1", 8080)

        var pendingLine = evh.createTask(client.readLine())

        var attempts = 0
        while #client._buffer == 0 and attempts < 20
            attempts += 1
            yield evh.sleep(10)
        end
        assert(#client._buffer > 0, "partial line was not buffered before cancellation")

        pendingLine.cancel()
        var line = yield client.readLine()
        assert(line == "hello world\n")

        try
            yield pendingLine
            assert(false, "cancelled read should have failed")
        except CancelledError _
        end

        yield client.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun writeReadUntilDelayed()
    @async
    fun server()
        var server = TCPListener()
        server.bind("0.0.0.0", 8080)
        
        server.listen()
        var client = yield server.accept()
        yield client.write(
            "GET /test HTTP/1.1\r\nHost: test.com\r\n\r\nGET /test2 HTTP/1.1\r\nHos"
        )
        yield evh.sleep(1000)
        yield client.write("t: test.com\r\n\r\n")
        yield client.close()
        yield server.close()
    end

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("127.0.0.1", 8080)

        var data1 = yield client.readUntil("\r\n\r\n")
        assert(data1 == "GET /test HTTP/1.1\r\nHost: test.com\r\n\r\n")

        var data2 = yield client.readUntil("\r\n\r\n")
        assert(data2 == "GET /test2 HTTP/1.1\r\nHost: test.com\r\n\r\n")

        var data3 = yield client.read(500)
        assert(!data3)

        var data4 = yield client.readUntil("\r\n\r\n")
        assert(!data4)

        assert(#client._buffer == 0)

        yield client.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun writeln()
    @async
    fun server()
        var server = TCPListener()
        server.bind("0.0.0.0", 8080)
        
        server.listen()
        var client = yield server.accept()
        yield client.write(yield client.readLine())
        yield client.close()
        yield server.close()
    end

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("127.0.0.1", 8080)
        yield client.writeln("Hello, World!")
        var data = yield client.readLine()
        assert(data == "Hello, World!\n")
        yield client.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun readLine()
    @async
    fun server()
        var server = TCPListener()
        server.bind("0.0.0.0", 8080)
        
        server.listen()
        var client = yield server.accept()
        yield client.write("line1\nline")
        yield client.write("2\nline3\n")
        yield client.close()
        yield server.close()
    end

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("127.0.0.1", 8080)

        var data1 = yield client.readLine()
        assert(data1 == "line1\n")

        var data2 = yield client.readLine()
        assert(data2 == "line2\n")

        var data3 = yield client.readLine()
        assert(data3 == "line3\n")

        var data4 = yield client.read()
        assert(!data4)

        var data5 = yield client.readLine()
        assert(!data5)

        assert(#client._buffer == 0)

        yield client.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun readUntilFail()
    @async
    fun server()
        var server = TCPListener()
        server.bind("0.0.0.0", 8080)
        
        server.listen()
        var client = yield server.accept()
        yield client.write("line1")
        yield client.close()
        yield server.close()
    end

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("127.0.0.1", 8080)

        var partial = yield client.readLine()
        assert(!partial.endsWith("\n"))

        assert(#client._buffer == 0)

        yield client.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun readUntilSeparatorSplitAcrossChunks()
    // Regression test for _drainUntilSep missing separators that straddle a
    // chunk boundary. The first write ends with "\r\n\r" (three of the four
    // separator bytes) and the second write, sent after a delay to force a
    // separate TCP segment, starts with "\n" (the final byte). The old code
    // searched each chunk in isolation and would hang forever on the first
    // readUntil because neither chunk contained the complete "\r\n\r\n".
    @async
    fun server()
        var server = TCPListener()
        server.bind("0.0.0.0", 8080)

        server.listen()
        var client = yield server.accept()
        yield client.write("GET /test HTTP/1.1\r\nHost: test.com\r\n\r")
        yield evh.sleep(1000)
        yield client.write("\nGET /test2 HTTP/1.1\r\nHost: test.com\r\n\r\n")
        yield client.close()
        yield server.close()
    end

    @async
    fun client()
        var client = TCPStream()
        yield client.connect("127.0.0.1", 8080)

        var data1 = yield client.readUntil("\r\n\r\n")
        assert(data1 == "GET /test HTTP/1.1\r\nHost: test.com\r\n\r\n")

        var data2 = yield client.readUntil("\r\n\r\n")
        assert(data2 == "GET /test2 HTTP/1.1\r\nHost: test.com\r\n\r\n")

        yield client.close()
    end

    evh.run(evh.all(server(), client()))
end

if __name__ == '__main__'
    run()
end
