#!/usr/bin/env jstar
importPaths.insert(0, './')
importPaths.insert(0, './tests')

import test for test, run

import event_horizon as evh
import event_horizon.async for async
import event_horizon.errors for EventHorizonException, StatusException
import event_horizon.tls for TLSStream
import event_horizon.uv.errors for Errno

static var CERT = "tests/certs/cert.pem"
static var KEY  = "tests/certs/key.pem"
static var PORT = 8089

static var SERVER_OPTS = {"cert": CERT, "key": KEY}
static var CLIENT_OPTS = {"ca": CERT}

static fun repeatedBlock(block, count)
    var chunks = []
    while count > 0
        chunks.add(block)
        count = count - 1
    end
    return chunks.join()
end

@test
fun listenConnect()
    var clientConnected = false
    var serverConnected = false

    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            serverConnected = true
            yield client.close()
            yield s.close()
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        clientConnected = true
        yield c.close()
    end

    evh.run(evh.all(server(), client()))
    assert(clientConnected and serverConnected)
end

@test
fun listenConnectVerified()
    // Client supplies the correct CA, handshake should succeed
    var connected = false

    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            yield client.close()
            yield s.close()
        end))
    end

    @async
    fun client()
        var c = TLSStream({"ca": CERT, "serverName": "localhost"})
        yield c.connect("127.0.0.1", PORT)
        connected = true
        yield c.close()
    end

    evh.run(evh.all(server(), client()))
    assert(connected)
end

@test
fun writeRead()
    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            try
                var data = yield client.read()
                yield client.write(data)
            ensure
                yield client.close()
                yield s.close()
            end
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        yield c.write("hello evh TLS")
        var data = yield c.read()
        assert(data == "hello evh TLS", "unexpected echo: {0}" % data)
        yield c.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun largeWriteReadCrossesTLSStagingBoundaries()
    // Crosses TLS_READ_CHUNK_SIZE, TLS_PLAIN_READ_CHUNK_SIZE, and recvBuf
    // capacity. This verifies that smaller libuv reads preserve ciphertext
    // across multiple TLS records.
    var payload = repeatedBlock("0123456789abcdef", 4096)  // 64 KiB

    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            try
                var data = yield client.read(#payload)
                assert(data == payload, "server saw corrupted large payload")
                yield client.write(data)
            ensure
                yield client.close()
                yield s.close()
            end
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        yield c.write(payload)
        var echoed = yield c.read(#payload)
        assert(echoed == payload, "client saw corrupted large echo")
        yield c.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun emptyWriteResolvesAndDoesNotBlockNextWrite()
    var emptyResolved = false
    var nextResolved = false
    var received = null

    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            try
                received = yield client.read()
            ensure
                yield client.close()
                yield s.close()
            end
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        yield c.write("")
        emptyResolved = true
        yield c.write("after empty")
        nextResolved = true
        yield c.close()
    end

    evh.run(evh.all(server(), client()))
    assert(emptyResolved, "empty TLS write did not resolve")
    assert(nextResolved, "write after empty TLS write did not resolve")
    assert(received == "after empty", "write after empty TLS write was not delivered")
end

@test
fun pendingWriteQueueSizeTracksUnencryptedPlaintext()
    var block = repeatedBlock("p", 4096)
    var large = repeatedBlock(block, 256)
    var queuedAfterWrite = null
    var queuedAfterResolve = null
    var serverRead = 0

    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            try
                while serverRead < #large
                    var data = yield client.read()
                    if !data
                        break
                    end
                    serverRead += #data
                end
            ensure
                yield client.close()
                yield s.close()
            end
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        var pendingWrite = c.write(large)
        queuedAfterWrite = c.pendingWriteQueueSize()
        yield pendingWrite
        queuedAfterResolve = c.pendingWriteQueueSize()
        yield c.close()
    end

    evh.run(evh.all(server(), client()))
    assert(queuedAfterWrite > 0, "large TLS write did not report queued plaintext")
    assert(queuedAfterResolve == 0, "TLS pending write queue did not drain")
    assert(serverRead == #large, "server did not read the full large write")
end

@test
fun queuedTLSWritesPreserveOrder()
    // Issue several writes before the peer reads everything. The native TLS
    // pending-write pump must resume in FIFO order as libuv write callbacks
    // drain the ciphertext queue.
    var first = repeatedBlock("a", 4096)
    var second = repeatedBlock("b", 4096)
    var third = repeatedBlock("c", 4096)
    var expected = first + second + third

    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            try
                var data = yield client.read(#expected)
                assert(data == expected, "queued TLS writes arrived out of order")
            ensure
                yield client.close()
                yield s.close()
            end
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        yield evh.all(c.write(first), c.write(second), c.write(third))
        yield c.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun readLine()
    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            try
                yield client.writeln("line one")
                yield client.writeln("line two")
            ensure
                yield client.close()
                yield s.close()
            end
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        var l1 = yield c.readLine()
        var l2 = yield c.readLine()
        assert(l1 == "line one\n", "unexpected line 1: '{0}'" % l1)
        assert(l2 == "line two\n", "unexpected line 2: '{0}'" % l2)
        yield c.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun readUntil()
    // Verify that StreamBuffer separator logic works correctly over TLS chunks
    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            try
                yield client.write("part1|part2|part3")
            ensure
                yield client.close()
                yield s.close()
            end
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        var chunk = yield c.readUntil("|")
        assert(chunk == "part1|", "unexpected chunk: '{0}'" % chunk)
        yield c.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun writeReadCountDelayed()
    // Server writes data in two batches separated by a timer gap, forcing the
    // client to accumulate bytes across two distinct TLS records. Exercises
    // read(N) spanning multiple tlsRawReadCallback invocations.
    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            try
                yield client.write("01234")
                yield evh.sleep(1000)
                yield client.write("56789")
            ensure
                yield client.close()
                yield s.close()
            end
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)

        var data1 = yield c.read(8)
        assert(data1 == "01234567", "unexpected: '{0}'" % data1)

        var data2 = yield c.read()
        assert(data2 == "89", "unexpected: '{0}'" % data2)

        var data3 = yield c.read()
        assert(!data3)

        assert(#c._buffer == 0)

        yield c.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun writeReadUntilDelayed()
    // Server sends a two-message HTTP-like payload split across two TLS records
    // with a timer gap between them. Exercises readUntil when the buffer must
    // accumulate across multiple network reads before the separator is found.
    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            try
                yield client.write(
                    "GET /test HTTP/1.1\r\nHost: test.com\r\n\r\nGET /test2 HTTP/1.1\r\nHos"
                )
                yield evh.sleep(1000)
                yield client.write("t: test.com\r\n\r\n")
            ensure
                yield client.close()
                yield s.close()
            end
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)

        var data1 = yield c.readUntil("\r\n\r\n")
        assert(data1 == "GET /test HTTP/1.1\r\nHost: test.com\r\n\r\n")

        var data2 = yield c.readUntil("\r\n\r\n")
        assert(data2 == "GET /test2 HTTP/1.1\r\nHost: test.com\r\n\r\n")

        var data3 = yield c.read(500)
        assert(!data3)

        var data4 = yield c.readUntil("\r\n\r\n")
        assert(!data4)

        assert(#c._buffer == 0)

        yield c.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun readUntilSeparatorSplitAcrossChunks()
    // Regression: the separator "\r\n\r\n" straddles two TLS records. The first
    // write ends with "\r\n\r" and the second (after a delay) begins with "\n".
    // StreamBuffer must search across the join point, not per-chunk.
    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            try
                yield client.write("GET /test HTTP/1.1\r\nHost: test.com\r\n\r")
                yield evh.sleep(1000)
                yield client.write("\nGET /test2 HTTP/1.1\r\nHost: test.com\r\n\r\n")
            ensure
                yield client.close()
                yield s.close()
            end
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)

        var data1 = yield c.readUntil("\r\n\r\n")
        assert(data1 == "GET /test HTTP/1.1\r\nHost: test.com\r\n\r\n")

        var data2 = yield c.readUntil("\r\n\r\n")
        assert(data2 == "GET /test2 HTTP/1.1\r\nHost: test.com\r\n\r\n")

        yield c.close()
    end

    evh.run(evh.all(server(), client()))
end

@test
fun closeConnectedResolves()
    var clientClosed = false
    var serverClosed = false

    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            yield client.close()
            serverClosed = true
            yield s.close()
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        yield c.close()
        clientClosed = true
    end

    evh.run(evh.all(server(), client()))
    assert(clientClosed, "client close did not resolve")
    assert(serverClosed, "server close did not resolve")
end

@test
fun closeWhileClosePendingRejects()
    var rejected = false
    var firstCloseResolved = false

    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            yield client.close()
            yield s.close()
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        var firstClose = c.close()
        firstClose.addDoneCallback(fun(done)
            try
                done.result()
                firstCloseResolved = true
            except Exception _
            end
        end)

        try
            yield c.close()
        except StatusException e
            rejected = true
            assert(e.status() == Errno.EALREADY, "expected UV_EALREADY, got {0}" % e.status())
        end

        yield firstClose
    end

    evh.run(evh.all(server(), client()))
    assert(rejected, "second close did not reject")
    assert(firstCloseResolved, "first close did not resolve")
end

@test
fun closeCancelsPendingRead()
    var readCanceled = false

    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            try
                yield client.read()
            ensure
                yield client.close()
                yield s.close()
            end
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        var pendingRead = c.read()
        yield c.close()

        try
            yield pendingRead
        except StatusException e
            readCanceled = e.status() == Errno.ECANCELED
        end
    end

    evh.run(evh.all(server(), client()))
    assert(readCanceled, "pending TLS read was not canceled by close")
end

@test
fun shutdownWithPendingWriteRejects()
    var block = repeatedBlock("y", 4096)
    var large = repeatedBlock(block, 256)
    var rejected = false
    var writeResolved = false

    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            try
                yield client.read(#large)
            ensure
                yield client.close()
                yield s.close()
            end
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        var pendingWrite = c.write(large)
        pendingWrite.addDoneCallback(fun(done)
            try
                done.result()
                writeResolved = true
            except Exception _
            end
        end)

        try
            yield c.shutdown()
        except EventHorizonException e
            rejected = true
            assert(e.err() == "TLS shutdown requires all pending writes to complete")
        end

        yield pendingWrite
        yield c.close()
    end

    evh.run(evh.all(server(), client()))
    assert(rejected, "shutdown with pending write did not reject")
    assert(writeResolved, "pending write did not resolve after rejected shutdown")
end

@test
fun writeAfterShutdownRejects()
    var rejected = false

    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            yield client.close()
            yield s.close()
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        yield c.shutdown()

        try
            yield c.write("after shutdown")
        except StatusException e
            rejected = true
            assert(e.status() == Errno.EPIPE, "expected UV_EPIPE, got {0}" % e.status())
        ensure
            yield c.close()
        end
    end

    evh.run(evh.all(server(), client()))
    assert(rejected, "write after shutdown did not reject")
end

@test
fun sockNamePeerName()
    @async
    fun server()
        var s = TLSStream(SERVER_OPTS)
        s.bind("0.0.0.0", PORT)
        yield s.listen(async(fun(client)
            yield client.close()
            yield s.close()
        end))
    end

    @async
    fun client()
        var c = TLSStream(CLIENT_OPTS)
        yield c.connect("127.0.0.1", PORT)
        var peer = c.peerName()
        assert(peer[0] == "127.0.0.1")
        assert(peer[1] == PORT)
        yield c.close()
    end

    evh.run(evh.all(server(), client()))
end

if __name__ == '__main__'
    run()
end
